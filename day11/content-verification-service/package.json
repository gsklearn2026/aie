{
  "name": "content-verification-service",
  "version": "1.0.0",
  "description": "AI-powered content verification service for quiz platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t content-verification-service .",
    "docker:run": "docker run -p 3003:3003 content-verification-service"
  },
  "dependencies": {
    "express": "^5.0.0",
    "@anthropic-ai/sdk": "^0.24.0",
    "bull": "^4.12.0",
    "redis": "^4.6.0",
    "joi": "^17.13.0",
    "winston": "^3.13.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.0",
    "uuid": "^10.0.0",
    "async-retry": "^1.3.3",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.0",
    "@types/jest": "^29.5.0",
    "redis-memory-server": "^0.10.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
