{
  "app": {
    "name": "AI Quiz Platform",
    "version": "1.0.0",
    "debug": false,
    "host": "0.0.0.0",
    "port": 8000
  },
  "database": {
    "echo": false,
    "pool_size": 5,
    "pool_timeout": 30,
    "pool_recycle": 3600
  },
  "gemini": {
    "model": "gemini-pro",
    "temperature": 0.7,
    "max_tokens": 1000,
    "rate_limit_per_minute": 60
  },
  "security": {
    "cors_origins": ["http://localhost:3000"],
    "session_timeout": 3600
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
