{
  "app": {
    "debug": false,
    "workers": 4
  },
  "database": {
    "url": "postgresql://user:password@localhost:5432/quiz_prod",
    "pool_size": 20,
    "pool_timeout": 60,
    "pool_recycle": 1800,
    "pool_pre_ping": true
  },
  "gemini": {
    "rate_limit_per_minute": 60,
    "timeout": 10,
    "retry_attempts": 3
  },
  "security": {
    "cors_origins": [],
    "session_timeout": 1800
  },
  "logging": {
    "level": "ERROR"
  },
  "features": {
    "ai_hints": true,
    "detailed_explanations": true,
    "performance_metrics": false
  }
}
